<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ashwinsathian.typester.caddy</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/caddy</string>
    <string>run</string>
    <string>--config</string>
    <string>/opt/typester/Caddyfile</string>
    <string>--adapter</string>
    <string>caddyfile</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>TYPESTER_RELEASE</key>
    <string>/opt/typester/releases/current</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>StandardOutPath</key>
  <string>/opt/typester/logs/caddy.out.log</string>
  <key>StandardErrorPath</key>
  <string>/opt/typester/logs/caddy.err.log</string>
</dict>
</plist>
