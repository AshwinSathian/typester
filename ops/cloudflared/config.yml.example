# Copy to ~/.cloudflared/typester-config.yml (this machine already runs other
# tunnels under the shared default ~/.cloudflared/config.yml - each project
# gets its own <project>-config.yml so they don't collide) and replace
# <TUNNEL_ID> after running:
#   cloudflared tunnel create typester
#   cloudflared tunnel route dns typester typester.ashwinsathian.com
#
# This binds the tunnel to Caddy on localhost only — cloudflared makes an
# outbound-only connection to Cloudflare's edge, so no inbound port is ever
# opened on this machine or the home network.

tunnel: <TUNNEL_ID>
credentials-file: /Users/ashwinsathian/.cloudflared/<TUNNEL_ID>.json

retries: 5
grace-period: 30s

ingress:
  - hostname: typester.ashwinsathian.com
    service: http://localhost:8787
    originRequest:
      connectTimeout: 10s
      tcpKeepAlive: 30s
      keepAliveConnections: 10
      httpHostHeader: typester.ashwinsathian.com
  - service: http_status:404
