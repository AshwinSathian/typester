## Typester static site — served locally, fronted by a Cloudflare Tunnel.
## Caddy terminates plain HTTP on localhost only; Cloudflare Tunnel handles the
## public TLS edge, so Caddy does not need (and must not open) a public port.
##
## The site address is deliberately `:8787` (port only, no "localhost" host
## part) with an explicit `bind 127.0.0.1`: Caddy treats a hostname in the
## site address as a Host-header matcher, not just a bind address, and
## Cloudflare forwards the tunnel's real public hostname
## (typester.ashwinsathian.com) to the origin - a `localhost:8787` address
## would only match requests with a literal `Host: localhost` and silently
## serve an empty response for everything else.

:8787 {
	bind 127.0.0.1
	root * {$TYPESTER_RELEASE:/Users/ashwinsathian/.typester/releases/current}/browser
	encode zstd gzip
	file_server

	# SPA fallback: unknown paths resolve to index.html so Angular's router
	# (client-side navigation for /play/*, /results, etc.) can take over.
	try_files {path} /index.html

	# Defense-in-depth headers. Angular ships hashed, non-inline bundles, so a
	# strict CSP with no 'unsafe-inline'/'unsafe-eval' is achievable.
	header {
		# base-uri must be 'self', not 'none': Angular's own <base href="/">
		# tag needs to be allowed to take effect, or the browser ignores it and
		# resolves every asset path relative to the current route instead of
		# root - breaks every deep link into a non-root route (e.g. /play/*,
		# a shared /results-equivalent link). style-src/script-src need
		# 'unsafe-inline' for Angular's SSR-emitted critical-CSS <style> and
		# the JSON-LD <script type="application/ld+json"> block in index.html -
		# there's no user-controlled data rendered into either, so the usual
		# XSS risk 'unsafe-inline' introduces doesn't apply here. Verified
		# against a real browser (Playwright), not just curl - this exact
		# combination is also what this account's other live app needs for
		# its own SSR hydration output.
		Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.datamuse.com"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	# Immutable, hashed build assets — safe to cache forever.
	@hashed path *.js *.css
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# index.html and the PWA manifest/service worker must always revalidate.
	@revalidate path /index.html /manifest.webmanifest /ngsw.json /ngsw-worker.js
	header @revalidate Cache-Control "no-cache"

	# Caddy's built-in MIME table doesn't know .webmanifest - browsers are
	# lenient about it, but the correct type is worth setting explicitly.
	@manifest path *.webmanifest
	header @manifest Content-Type "application/manifest+json"

	log {
		output file /Users/ashwinsathian/.typester/logs/caddy-access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
